{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  // All categories at error; "nursery" stays off (unstable rules). Every "off"
  // below carries its justification. Mirrors the jx-platform baseline, adapted
  // for a WordPress/React (DataViews) admin app.
  "categories": {
    "correctness": "error",
    "nursery": "off",
    "pedantic": "error",
    "perf": "error",
    "restriction": "error",
    "style": "error",
    "suspicious": "error"
  },
  "ignorePatterns": ["build", "vendor", "node_modules", "**/*.map", "**/*.d.ts"],
  "overrides": [
    {
      // The rolldown config is a Node build script; node: imports are the point,
      // and a bundler config file must be a default export.
      "files": ["rolldown.config.ts"],
      "rules": {
        "import/no-nodejs-modules": "off",
        "import/no-default-export": "off",
        "no-console": "off"
      }
    }
  ],
  "plugins": ["import", "unicorn", "oxc", "typescript", "react", "jsx-a11y"],
  "rules": {
    // ─── Configured (enabled with options) ────────────────────────────────
    // `== null` is the deliberate null-or-undefined check; all else strict.
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "eslint/no-empty": ["error", { "allowEmptyCatch": true }],
    "eslint/no-empty-function": ["error", { "allow": ["arrowFunctions"] }],
    "eslint/no-plusplus": ["error", { "allowForLoopAfterthoughts": true }],
    "eslint/no-use-before-define": ["error", { "functions": false, "variables": false }],
    // `void promise` is the explicit fire-and-forget marker.
    "eslint/no-void": ["error", { "allowAsStatement": true }],
    "max-classes-per-file": ["error", 2],
    "new-cap": ["error", { "capIsNew": false }],
    // Members are implicitly public; only private/protected must be explicit.
    "typescript/explicit-member-accessibility": ["error", { "accessibility": "no-public" }],

    // ─── Off: platform/domain conflicts ───────────────────────────────────
    // null is a wire value throughout (REST rows, Cloudflare JSON responses).
    "unicorn/no-null": "off",
    "no-underscore-dangle": "off",

    // ─── Off: redundant with the TypeScript compiler ──────────────────────
    // tsc strict owns undefined-identifier checking (lint has no type info).
    "eslint/no-undef": "off",
    // Inference-first; tsc strict validates every boundary.
    "typescript/explicit-function-return-type": "off",
    "typescript/explicit-module-boundary-types": "off",

    // ─── Off: React automatic runtime ─────────────────────────────────────
    // JSX transform is automatic (react/jsx-runtime); React need not be in scope.
    "react/react-in-jsx-scope": "off",

    // ─── Off/adjusted: React rules that fight this app's shape ─────────────
    // We use .tsx by design.
    "react/jsx-filename-extension": "off",
    // A single-file admin app is intentional (keeps the plugin surface small).
    "react/no-multi-comp": "off",
    // Fast Refresh is a dev-HMR concern; irrelevant to a WP admin bundle.
    "react/only-export-components": "off",
    // Inline styles on @wordpress/components are deliberate here.
    "react/forbid-component-props": "off",
    // DataViews actions pass RenderModal components as props by contract.
    "react/no-unstable-nested-components": ["error", { "allowAsProps": true }],

    // ─── Off: TypeScript idiom ────────────────────────────────────────────
    "eslint/no-undefined": "off",

    // ─── Off: WordPress convention ────────────────────────────────────────
    // i18n `/* translators: … */` comments must stay lowercase for wp i18n tooling.
    "eslint/capitalized-comments": "off",

    // ─── Off: contradicts an enabled rule or the formatter ────────────────
    "eslint/no-eq-null": "off",
    "import/prefer-default-export": "off",
    "import/no-named-export": "off",
    "no-duplicate-imports": "off",
    "unicorn/number-literal-case": "off",

    // ─── Off: deliberate architecture ─────────────────────────────────────
    "no-await-in-loop": "off",
    "eslint/require-await": "off",
    "import/no-relative-parent-imports": "off",
    "no-console": "off",
    "unicorn/consistent-function-scoping": "off",
    "unicorn/prefer-global-this": "off",

    // ─── Off: style preferences that fight convention ─────────────────────
    "func-style": "off",
    "id-length": "off",
    "complexity": "off",
    "max-depth": "off",
    "max-lines": "off",
    "max-lines-per-function": "off",
    "max-params": "off",
    "max-statements": "off",
    // Status codes, sizes, and pixel dimensions read fine inline next to their use.
    "no-magic-numbers": "off",
    "no-continue": "off",
    "no-inline-comments": "off",
    "no-negated-condition": "off",
    "unicorn/no-negated-condition": "off",
    "no-nested-ternary": "off",
    "unicorn/no-nested-ternary": "off",
    "no-ternary": "off",
    "init-declarations": "off",
    "sort-keys": "off",
    "sort-imports": "off",
    "import/exports-last": "off",
    "import/group-exports": "off",
    "import/max-dependencies": "off",
    "unicorn/import-style": "off",
    "eslint/prefer-named-capture-group": "off",
    "eslint/require-unicode-regexp": "off",

    // ─── Off: ES-downlevel restrictions (irrelevant on modern targets) ─────
    "oxc/no-async-await": "off",
    "oxc/no-optional-chaining": "off",
    "oxc/no-rest-spread-properties": "off"
  }
}
